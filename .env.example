# =========================
# APP CONFIG
# =========================
APP_ENV=dev
PORT=8000

# =========================
# SLACK (REQUIRED)
# =========================
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_DEFAULT_CHANNEL=#alerts

# =========================
# LLM
# =========================

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# =========================
# KUBERNETES
# =========================
KUBECONFIG=/home/your-user/.kube/config
K8S_NAMESPACE=default

# =========================
# MCP / AGENT CONFIG
# =========================
POLL_INTERVAL_SECONDS=30
AUTO_APPROVE_THRESHOLD=0.8
ENABLE_BACKGROUND_POLLING=false
CHECKPOINT_STORE_PATH=data/langgraph-checkpoints.pkl
VERIFY_TIMEOUT_SECONDS=20

# =========================
# PROMETHEUS (OPTIONAL)
# =========================
PROMETHEUS_URL=http://localhost:9090

# =========================
# DEV / TUNNEL (OPTIONAL)
# =========================
PUBLIC_BASE_URL=https://your-cloudflared-url

# =========================
# STELLAR (OPTIONAL BONUS)
# =========================
STELLAR_NETWORK=testnet
STELLAR_SECRET_KEY=your-stellar-secret
STELLAR_RPC_URL=
STELLAR_CONTRACT_ID=
